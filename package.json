{
  "name": "puzzling-potions",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "prestart": "run-s assets",
    "start": "vite --open",
    "dev:game": "pnpm --filter @puzzling-potions/game dev",
    "dev:editor": "pnpm --filter @puzzling-potions/level-editor dev",
    "assets": "assetpack",
    "prebuild": "run-s clean format:check lint assets types",
    "build": "vite build",
    "types": "tsc",
    "prepreview": "run-s build",
    "preview": "vite preview --open",
    "clean": "rimraf public/assets/* dist/* .assetpack/*",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.2.95",
    "@headlessui/react": "^2.2.9",
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.2.7",
    "clsx": "^2.1.1",
    "easy-peasy": "^6.1.0",
    "eventemitter3": "^5.0.4",
    "framer-motion": "^12.36.0",
    "gsap": "^3.13.0",
    "pixi.js": "^8.14.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@assetpack/core": "^1.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.57.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
